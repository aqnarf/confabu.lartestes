{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": [
        "index.html",
        "busca.html",
        "livro.html",
        "leitor.html",
        "termos.html",
        "styles.css",
        "app.js"
      ]
    }
  },
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
